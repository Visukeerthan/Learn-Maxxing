<div class="main-container">
  <div class="card" style="max-width: 450px; margin: 0 auto;">
    <h2 style="text-align: center; margin-bottom: 20px;">Join Learn Maxxing 🚀</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :email %><br />
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "your@email.com" %>
      </div>

      <div class="form-group">
        <%= f.label :password %>
        <% if @minimum_password_length %>
          <em style="font-size: 0.8rem; color: var(--text-muted);">(<%= @minimum_password_length %> chars min)</em>
        <% end %><br />
        <%= f.password_field :password, autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation %><br />
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <hr style="border: 0; border-top: 1px solid #e2e8f0; margin: 20px 0;">

      <%# --- THE ROLE SELECTOR --- %>
      <div class="form-group">
        <%= f.label :role, "Sign up as a:", style: "font-weight: 600;" %>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 8px;">Trainers can create courses; Students can enroll in them.</p>
        <%= f.select :role, 
            User.roles.keys.map { |r| [r.humanize, r] }, 
            {}, 
            { class: "form-control", style: "width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; background: #fff;" } 
        %>
      </div>

      <div class="actions" style="margin-top: 25px;">
        <%= f.submit "Create Account", class: "btn btn-primary", style: "width: 100%;" %>
      </div>
    <% end %>

    <div style="margin-top: 20px; text-align: center; border-top: 1px solid #eee; padding-top: 15px;">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>