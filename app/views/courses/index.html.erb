<div class="section-header">
  <h1>Available Courses</h1>
  <% if current_user&.instructor? %>
    <%= link_to "+ New Course", new_course_path, class: "btn btn-primary" %>
  <% end %>
</div>


<div class="courses-grid">
  <% @courses.each do |course| %>
    <div class="card course-card">
      <div class="course-accent"></div>
      <h2><%= course.title %></h2>
      <p><%= truncate(course.description, length: 100) %></p>
      <div class="course-footer">
        <span class="instructor-tag">By <%= course.user.email.split('@').first %></span>
        <%= link_to "View Course", course_path(course), class: "btn btn-outline" %>
      </div>
    </div>
  <% end %>
</div>