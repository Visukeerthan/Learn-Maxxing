<div class="main-container">
  <div class="card">
    <h1 style="border-bottom: 2px solid var(--primary); display: inline-block; margin-bottom: 20px;">
      Add New Lesson to: <%= @course.title %>
    </h1>

    <%# The form must use the array [@course, @lesson] for nested routes %>
    <%= form_with(model: [@course, @lesson]) do |f| %>
      
      <div class="form-group">
        <%= f.label :title, "Lesson Title", style: "font-weight: bold;" %>
        <%= f.text_field :title, placeholder: "e.g. Introduction to Ruby", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :body, "Lesson Content (Markdown/Text)", style: "font-weight: bold;" %>
        <%= f.text_area :body, rows: 10, placeholder: "Enter the lesson details here...", required: true %>
      </div>

      <div style="margin-top: 20px;">
        <%= f.submit "Publish Lesson", class: "btn btn-primary" %>
        <%= link_to "Cancel", course_path(@course), class: "btn btn-outline", style: "margin-left: 10px;" %>
      </div>
      
    <% end %>
  </div>

  <div style="margin-top: 20px;">
    <%= link_to "← Back to Course Details", course_path(@course), class: "back-link" %>
  </div>
</div>